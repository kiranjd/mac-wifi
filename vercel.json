{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.macwifi.live"
        }
      ],
      "destination": "https://macwifi.live/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/website"
    },
    {
      "source": "/assets/:path*",
      "destination": "/website/assets/:path*"
    },
    {
      "source": "/styles.css",
      "destination": "/website/styles.css"
    },
    {
      "source": "/main.js",
      "destination": "/website/main.js"
    },
    {
      "source": "/blog.css",
      "destination": "/website/blog.css"
    },
    {
      "source": "/content.css",
      "destination": "/website/content.css"
    },
    {
      "source": "/blog",
      "destination": "/website/blog"
    },
    {
      "source": "/blog/:slug",
      "destination": "/website/blog/:slug"
    },
    {
      "source": "/help/activate-license",
      "destination": "/website/help/activate-license"
    },
    {
      "source": "/help/getting-started",
      "destination": "/website/help/getting-started"
    },
    {
      "source": "/download",
      "destination": "/website/download"
    },
    {
      "source": "/robots.txt",
      "destination": "/website/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/website/sitemap.xml"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
